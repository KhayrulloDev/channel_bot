# Telegram BotFather'dan olingan token
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio'dan olingan Gemini API kalit (https://aistudio.google.com/apikey)
# Bu kalit BARCHA foydalanuvchilar uchun umumiy ishlatiladi
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini modeli (ixtiyoriy, standart: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Ixtiyoriy: bot egasi Telegram ID'lari, vergul bilan ajratilgan.
# Faqat /stats kabi global statistika buyrug'i uchun ishlatiladi.
# Oddiy foydalanuvchilar buni to'ldirishi shart emas — ular /connect orqali
# o'z kanalini mustaqil ulay oladi.
# O'z ID'ingizni bilish uchun @userinfobot ga yozing
SUPER_ADMIN_IDS=123456789

